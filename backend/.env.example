# Backend
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/emmanuel-portfolio
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins (e.g. http://localhost:5173,https://your-app.vercel.app)
CORS_ORIGIN=http://localhost:5173

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Seed / default admin (used by npm run seed — change password after first login)
ADMIN_EMAIL=admin@emmanuelocheme.com
ADMIN_PASSWORD=QuantroAdmin2025!
